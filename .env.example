# Profitshare affiliate API credentials.
# Used ONLY at authoring/build time to resolve affiliate links (static-safe mode).
# These never reach the browser and must NEVER be committed.
#
# Copy this file to .env and fill in your real values:
#   cp .env.example .env
PROFITSHARE_API_USER=your_api_user
PROFITSHARE_API_KEY=your_api_key
