---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../../components/Breadcrumbs.astro';
import ProductCard from '../../../components/ProductCard.astro';
import EmptyState from '../../../components/EmptyState.astro';
import { LOCALES, isLocale, type Locale } from '../../../config';
import { pagePath, mirrorAlternates, mirrorTranslations } from '../../../i18n/utils';
import { useTranslations } from '../../../i18n/ui';
import { getProducts, getCategories } from '../../../lib/content';

export function getStaticPaths() {
  return LOCALES.map((locale) => ({ params: { locale } }));
}

const locale = (isLocale(Astro.params.locale) ? Astro.params.locale : 'ro') as Locale;
const t = useTranslations(locale);
const [products, categories] = await Promise.all([getProducts(locale), getCategories(locale)]);
const categoryName = new Map(categories.map((c) => [c.id, c.data.name[locale]]));
const title = t('nav.products');
---

<BaseLayout
  locale={locale}
  title={title}
  description={t('meta.products')}
  alternates={mirrorAlternates('products')}
  translations={mirrorTranslations('products')}
>
  <section class="section">
    <div class="container">
      <Breadcrumbs locale={locale}
        items={[{ label: t('common.home'), href: pagePath(locale) }, { label: title }]}
      />
      <h1>{title}</h1>
      <div class="grid grid-3" style="margin-top:1.75rem">
        {
          products.map((product) => (
            <ProductCard
              product={product}
              locale={locale}
              href={pagePath(locale, 'products', product.id)}
              categoryLabel={categoryName.get(product.data.category.id)}
            />
          ))
        }
      </div>
      {products.length === 0 && <EmptyState message={t('empty.products')} />}
    </div>
  </section>
</BaseLayout>
