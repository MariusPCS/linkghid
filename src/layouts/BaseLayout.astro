---
import '../styles/global.css';
import { type Locale } from '../config';
import { useTranslations } from '../i18n/ui';
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

interface Alternate {
  hreflang: string;
  href: string;
}

interface Props {
  title: string;
  description: string;
  locale: Locale;
  canonical?: string;
  ogType?: 'website' | 'article';
  ogImage?: string;
  noindex?: boolean;
  alternates?: Alternate[];
  jsonLd?: Record<string, unknown> | Record<string, unknown>[];
  /** Per-locale URLs for the language switcher (e.g. translated content). */
  translations?: Partial<Record<Locale, string>>;
}

const {
  title,
  description,
  locale,
  canonical,
  ogType,
  ogImage,
  noindex,
  alternates,
  jsonLd,
  translations,
} = Astro.props;

const t = useTranslations(locale);
---

<!doctype html>
<html lang={locale}>
  <head>
    <BaseHead
      title={title}
      description={description}
      locale={locale}
      canonical={canonical}
      ogType={ogType}
      ogImage={ogImage}
      noindex={noindex}
      alternates={alternates}
      jsonLd={jsonLd}
    />
  </head>
  <body>
    <a class="skip-link" href="#main">{t('nav.skipToContent')}</a>
    <Header locale={locale} translations={translations} />
    <main id="main">
      <slot />
    </main>
    <Footer locale={locale} />
  </body>
</html>
